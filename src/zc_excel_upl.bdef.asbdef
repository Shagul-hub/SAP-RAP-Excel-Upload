projection;
strict (2);

define behavior for ZC_EXCEL_UPL alias User {

  use create;
  use update;
  use delete;

  use action uploadExcelData;
  use action downloadExcel;

  use association _UserDev { create; }

}

define behavior for ZC_EXCEL_UPL_DEV alias UserDev {

  use update;
  use delete;

  use association _User;

}